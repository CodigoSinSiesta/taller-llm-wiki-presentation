import Slide03IdeaKarpathy from '../components/slides/Slide03IdeaKarpathy.svelte';
import Slide04Anatomia from '../components/slides/Slide04Anatomia.svelte';
import Slide05Plantillas from '../components/slides/Slide05Plantillas.svelte';
