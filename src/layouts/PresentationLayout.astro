---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Taller LLM Wiki — Presentación' } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content="Taller práctico para montar tu propio wiki personal mantenido por tu agente de IA (Claude, Codex, OpenCode, Copilot…), basado en el patrón LLM Wiki de Andrej Karpathy." />
    <link rel="icon" type="image/svg+xml" href="favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body>
    <slot />
  </body>
</html>
