---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Taller LLM Wiki — Código Sin Siesta' } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content="Taller práctico para construir una wiki semántica con LLMs. Por Código Sin Siesta." />
    <link rel="icon" type="image/svg+xml" href="favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body>
    <!-- V4 slide chrome: top accent bar + breadcrumb + footer -->
    <div class="slide-accent-bar" aria-hidden="true"></div>
    <div class="slide-breadcrumb" aria-hidden="true">
      <div class="crumbs">
        <span class="pulse-dot"></span>
        <span class="org">código sin siesta</span>
        <span class="sep">/</span>
        <span class="deck">taller-llm-wiki</span>
      </div>
      <div class="counter" id="slide-counter">01 / 12</div>
    </div>
    <div class="slide-footer" aria-hidden="true">
      <span>Hecho con <span class="heart">♥</span> por Código Sin Siesta · 2026</span>
      <span>← / → · Esc</span>
    </div>
    <slot />
    <script is:inline>
      (function () {
        const counter = document.getElementById('slide-counter');
        if (!counter) return;
        const update = () => {
          const slides = Array.from(document.querySelectorAll('.swiper-slide'));
          const total = slides.length || 12;
          const activeIdx = slides.findIndex((s) => s.classList.contains('swiper-slide-active'));
          const idx = activeIdx >= 0 ? activeIdx + 1 : 1;
          counter.textContent = String(idx).padStart(2, '0') + ' / ' + String(total).padStart(2, '0');
        };
        const observe = () => {
          const slides = document.querySelectorAll('.swiper-slide');
          if (slides.length === 0) { requestAnimationFrame(observe); return; }
          slides.forEach((s) => {
            const obs = new MutationObserver(update);
            obs.observe(s, { attributes: true, attributeFilter: ['class'] });
          });
          update();
        };
        document.addEventListener('DOMContentLoaded', observe);
        if (document.readyState !== 'loading') observe();
      })();
    </script>
  </body>
</html>
